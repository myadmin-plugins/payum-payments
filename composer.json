{
	"name": "detain/myadmin-payum-payments",
	"type": "myadmin-plugin",
	"description": "Payum payment gateway integration plugin for the MyAdmin control panel, providing PayPal Express Checkout, Stripe, and recurring billing support with Doctrine ORM/ODM and filesystem storage backends.",
	"keywords": [
		"payum",
		"payment",
		"gateway",
		"paypal",
		"stripe",
		"billing",
		"recurring",
		"myadmin"
	],
	"license": "LGPL-2.1-only",
	"authors": [
		{
			"name": "Joe Huss",
			"homepage": "https://my.interserver.net/"
		}
	],
	"config": {
		"bin-dir": "vendor/bin",
		"minimum-stability": "dev"
	},
	"require": {
		"php": ">=8.2",
		"ext-soap": "*",
		"symfony/event-dispatcher": "^5.0|^6.0|^7.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"autoload": {
		"psr-4": {
			"Detain\\MyAdminPayum\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Detain\\MyAdminPayum\\Tests\\": "tests/"
		}
	}
}
